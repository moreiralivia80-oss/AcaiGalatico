@page
@model acaigalatico.Web.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Minha Conta";
    Layout = "_Layout";
}

<div class="position-relative" style="min-height: 100vh; padding-top: 40px; padding-bottom: 60px; background: url('/images/galaxiaa.jpg?v=2') no-repeat center center/cover; background-attachment: fixed;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 0;"></div>
    
    <div class="container position-relative" style="z-index: 1;">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                
                <!-- CAIXA ÚNICA DE PERFIL (Consolidada) -->
                <div class="glass-card p-4 p-md-5" style="border-radius: 32px; border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.03); backdrop-filter: blur(25px); box-shadow: 0 25px 50px rgba(0,0,0,0.5);">
                    
                    <form id="profile-form" method="post" asp-page-handler="UpdateProfile" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4" role="alert"></div>
                        
                        <!-- Header com Foto e Nome -->
                        <div class="d-flex align-items-center gap-4 mb-5 pb-4 border-bottom border-white border-opacity-10">
                            <div class="position-relative" style="width: 100px; height: 100px; flex-shrink: 0;">
                                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                                {
                                    <img src="@Model.ProfilePictureUrl" alt="Perfil" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 3px solid #e056fd; box-shadow: 0 0 15px rgba(224,86,253,0.3);" />
                                }
                                else
                                {
                                    <div style="width: 100%; height: 100%; border-radius: 50%; background: rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; border: 2px dashed rgba(255,255,255,0.2);">
                                        <i class="fas fa-user text-white-50" style="font-size: 40px;"></i>
                                    </div>
                                }
                                <label for="Input_ProfilePhoto" class="btn btn-sm btn-primary position-absolute bottom-0 end-0 rounded-circle" style="width: 32px; height: 32px; background: linear-gradient(45deg, #9b59b6, #e056fd); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-camera" style="font-size: 12px;"></i>
                                </label>
                                <input asp-for="Input.ProfilePhoto" type="file" class="d-none" accept="image/*" onchange="this.form.submit()" />
                            </div>
                            <div>
                                <h3 class="text-white fw-bold m-0">@Model.FirstName</h3>
                                <p class="text-white-50 m-0 small">@Model.Email</p>
                                <span class="badge bg-purple-soft bg-opacity-10 text-white-50 mt-2 rounded-pill border border-secondary border-opacity-25" style="font-size: 0.7rem; letter-spacing: 1px;">CLIENTE GALÁCTICO</span>
                            </div>
                        </div>

                        <!-- Campos de Edição (Grid Lado a Lado) -->
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Input.NewUserName" class="form-label text-white-50 small fw-bold text-uppercase mb-2">Nome de usuário</label>
                                <input asp-for="Input.NewUserName" class="form-control" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 16px; padding: 12px 20px;" />
                                <span asp-validation-for="Input.NewUserName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.NewEmail" class="form-label text-white-50 small fw-bold text-uppercase mb-2">E-mail principal</label>
                                <input asp-for="Input.NewEmail" class="form-control" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 16px; padding: 12px 20px;" />
                                <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.PhoneNumber" class="form-label text-white-50 small fw-bold text-uppercase mb-2">Telefone celular</label>
                                <input asp-for="Input.PhoneNumber" class="form-control" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 16px; padding: 12px 20px;" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Botões de Ação -->
                        <div class="mt-5 d-flex flex-wrap gap-3">
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-3 fw-bold flex-grow-1 flex-md-grow-0" style="background: linear-gradient(90deg, #9b59b6, #e056fd); border: none; min-width: 200px;">
                                <i class="fas fa-save me-2"></i> Salvar Perfil
                            </button>
                            
                            <a asp-page="./ChangePassword" class="btn btn-outline-light rounded-pill px-4 py-3 fw-bold flex-grow-1 flex-md-grow-0" style="border: 2px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05);">
                                <i class="fas fa-lock me-2"></i> Alterar Senha
                            </a>
                        </div>
                    </form>

                    <!-- Meus Pedidos -->
                    <div class="mt-5 pt-5 border-top border-white border-opacity-10">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="text-white m-0 fw-bold"><i class="fas fa-receipt text-warning me-2"></i> Meus Pedidos</h5>
                            <span class="badge rounded-pill bg-primary" style="padding: 8px 15px;">@Model.OrdersCount</span>
                        </div>
                        
                        @if (Model.Orders?.Count > 0)
                        {
                            <div class="row g-3">
                                @foreach (var o in Model.Orders)
                                {
                                    <div class="col-md-6">
                                        <div class="p-4 h-100" style="background: rgba(255,255,255,0.03); border-radius: 20px; border: 1px solid rgba(255,255,255,0.08);">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="text-white fw-bold">Pedido #@o.Id</span>
                                                <span class="badge bg-info bg-opacity-25 text-white" style="font-size: 0.7rem;">@o.Status.ToUpper()</span>
                                            </div>
                                            <div class="text-white-50 small mb-2">@o.Data.ToString("dd/MM/yyyy HH:mm")</div>
                                            <div class="text-white fw-bold">R$ @o.ValorTotal.ToString("0.00")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-white-50 text-center py-5 bg-dark bg-opacity-10 rounded-4 border border-dashed border-secondary border-opacity-25">
                                <i class="fas fa-box-open d-block mb-3 opacity-25" style="font-size: 3rem;"></i>
                                Você ainda não tem pedidos realizados.
                            </div>
                        }
                    </div>

                    <!-- Exclusão de Conta (Link Discreto) -->
                    <div class="mt-5 pt-4 text-center">
                        <form method="post" asp-page-handler="DeleteAccount">
                            <button type="submit" class="btn btn-link text-danger text-decoration-none small opacity-50 hover-opacity-100 transition-all" onclick="return confirm('Tem certeza que deseja excluir sua conta permanentemente?')">
                                <i class="fas fa-user-slash me-1"></i> Excluir minha conta galáctica
                            </button>
                        </form>
                    </div>

                </div> <!-- Fim da Glass Card -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .transition-all { transition: all 0.3s ease; }
        .hover-opacity-100:hover { opacity: 1 !important; }
        .form-control:focus {
            background: rgba(255,255,255,0.1) !important;
            border-color: #e056fd !important;
            box-shadow: 0 0 15px rgba(224,86,253,0.2) !important;
            color: white !important;
        }
    </style>
}
