@page
@model acaigalatico.Web.Areas.Identity.Pages.Account.Manage.SettingsModel
@{
    ViewData["Title"] = "Configurações";
}

<div class="position-relative" style="min-height: 100vh; padding-top: 130px; padding-bottom: 60px; background: url('/images/galaxiaa.jpg?v=2') no-repeat center center/cover;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 0;"></div>
    <div class="container position-relative" style="z-index: 1;">
    <div class="row g-4">
        <div class="col-xl-4">
        <div class="glass-card p-4" style="border-radius: 20px;">
            <div class="d-flex align-items-center mb-3">
                <div class="me-3" style="width: 60px; height: 60px; border-radius: 50%; background:#2d5a27; display:flex; align-items:center; justify-content:center; box-shadow:0 8px 22px rgba(45,90,39,.35);">
                    <i class="fas fa-user text-white" style="font-size: 22px;"></i>
                </div>
                <div>
                    <div class="text-white fw-bold">@User.Identity?.Name</div>
                    <small class="text-white-50">Configurações da conta</small>
                </div>
            </div>
            <hr class="border-secondary border-opacity-50">
            <ul class="list-unstyled m-0">
                <li class="d-flex justify-content-between align-items-center py-2">
                    <a class="text-white text-decoration-none d-flex justify-content-between w-100" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <span><i class="fas fa-id-badge me-2 text-warning"></i> Meu Perfil</span>
                        <i class="fas fa-chevron-right text-white-50"></i>
                    </a>
                </li>
                <li class="d-flex justify-content-between align-items-center py-2">
                    <a class="text-white text-decoration-none d-flex justify-content-between w-100" asp-area="Identity" asp-page="/Account/Manage/Settings">
                        <span><i class="fas fa-cog me-2 text-warning"></i> Configurações</span>
                        <i class="fas fa-chevron-right text-white-50"></i>
                    </a>
                </li>
                <li class="d-flex justify-content-between align-items-center py-2">
                    <a class="text-white text-decoration-none d-flex justify-content-between w-100" asp-area="Identity" asp-page="/Account/Manage/Notifications">
                        <span><i class="fas fa-bell me-2 text-warning"></i> Notificações</span>
                        <i class="fas fa-chevron-right text-white-50"></i>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    <div class="col-xl-8">
        <div class="glass-card p-4" style="border-radius: 20px;">
            <h5 class="text-white fw-bold mb-3"><i class="fas fa-sliders-h text-warning me-2"></i> Preferências</h5>
            <form method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-white-50">Tema</label>
                        <select class="form-select bg-dark text-white border-0" asp-for="Input.Theme">
                            <option value="dark">Escuro</option>
                            <option value="light">Claro</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white-50">Idioma</label>
                        <select class="form-select bg-dark text-white border-0" asp-for="Input.Language">
                            <option value="pt-BR">Português (Brasil)</option>
                            <option value="en">English</option>
                        </select>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="fas fa-check me-2"></i> Salvar
                    </button>
                </div>
            </form>
            @if (TempData["SettingsSaved"] != null)
            {
                <div class="alert alert-success mt-4" role="alert" style="border-radius:12px;">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SettingsSaved"]
                </div>
            }
        </div>
        </div>
    </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
