@{
    ViewData["Title"] = "Configurar Métricas";
}

<div class="container" style="padding-top: 130px; padding-bottom: 50px;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="glass-card p-5 animate__animated animate__fadeInUp">
                <div class="text-center mb-4">
                    <i class="fas fa-sliders-h fa-3x text-white mb-3"></i>
                    <h2 class="text-white fw-bold">Configurar Métricas</h2>
                    <p class="text-white-50">Ajuste os números do seu painel administrativo</p>
                </div>

                <form asp-action="UpdateMetrics" method="post">
                    <div class="mb-4">
                        <label class="form-label text-white-50 fw-bold">Vendas Hoje</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-0 text-white"><i class="fas fa-shopping-cart"></i></span>
                            <input type="number" name="vendasHoje" class="form-control bg-dark border-0 text-white" value="@ViewBag.VendasHoje" min="0">
                        </div>
                        <small class="text-info">Define a quantidade total de vendas registradas para hoje.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 fw-bold">Total de Clientes</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-0 text-white"><i class="fas fa-users"></i></span>
                            <input type="number" name="totalClientes" class="form-control bg-dark border-0 text-white" value="@ViewBag.TotalClientes" min="0">
                        </div>
                        <small class="text-info">Ajusta o contador total de clientes na base de dados.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 fw-bold">Faturamento Total (R$)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-0 text-white">R$</span>
                            <input type="text" name="faturamento" class="form-control bg-dark border-0 text-white" value="@ViewBag.Faturamento.ToString("F2")">
                        </div>
                        <small class="text-info">Adiciona um registro de faturamento para atingir o valor desejado.</small>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold" style="background: linear-gradient(90deg, #9b59b6, #e056fd); border: none;">
                            <i class="fas fa-save me-2"></i> Salvar Alterações
                        </button>
                        <a asp-action="Index" class="btn btn-outline-light rounded-pill">Cancelar</a>
                    </div>
                </form>

                <hr class="my-5 border-secondary">

                <div class="text-center">
                    <h5 class="text-white mb-3">Opções Rápidas</h5>
                    <form asp-action="SeedMockData" method="post">
                        <button type="submit" class="btn btn-sm btn-info rounded-pill px-4">
                            <i class="fas fa-magic me-2"></i> Gerar Dados de Exemplo
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>