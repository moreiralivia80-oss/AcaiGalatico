@using acaigalatico.Domain.Entities
@model IEnumerable<acaigalatico.Application.DTOs.ProdutoDTO>

@{
    ViewData["Title"] = "Painel Administrativo";
}

<div class="container-fluid" style="padding-top: 100px; padding-bottom: 50px;">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-white mb-1">Painel Administrativo</h2>
            <p class="text-white-50 m-0">Gerencie todos os aspectos do Açaí Galáctico</p>
            <a asp-action="EditMetrics" class="btn btn-sm btn-outline-light mt-2 rounded-pill">
                <i class="fas fa-edit me-1"></i> Configurar Métricas
            </a>
        </div>
        <div class="d-flex gap-2">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                 <button type="submit" class="btn btn-outline-danger px-4 rounded-pill">
                    <i class="fas fa-sign-out-alt me-2"></i> Sair
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 bg-success bg-opacity-25 text-white border-0" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 bg-danger bg-opacity-25 text-white border-0" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <!-- Produtos -->
        <div class="col-md-3">
            <div class="glass-card p-4 d-flex align-items-center">
                <div class="icon-box me-3 bg-purple-soft">
                    <i class="fas fa-box-open fs-4 text-white"></i>
                </div>
                <div>
                    <small class="text-white-50 d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Produtos</small>
                    <h3 class="text-white m-0 fw-bold">@Model.Count()</h3>
                </div>
            </div>
        </div>
        
        <!-- Vendas Hoje -->
        <div class="col-md-3">
            <div class="glass-card p-4 d-flex align-items-center">
                <div class="icon-box me-3 bg-teal-soft">
                    <i class="fas fa-file-invoice-dollar fs-4 text-white"></i>
                </div>
                <div>
                    <small class="text-white-50 d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Vendas Hoje</small>
                    <h3 class="text-white m-0 fw-bold">@ViewBag.VendasHoje</h3>
                </div>
            </div>
        </div>

        <!-- Clientes -->
        <div class="col-md-3">
            <div class="glass-card p-4 d-flex align-items-center">
                <div class="icon-box me-3 bg-blue-soft">
                    <i class="fas fa-users fs-4 text-white"></i>
                </div>
                <div>
                    <small class="text-white-50 d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Clientes</small>
                    <h3 class="text-white m-0 fw-bold">@ViewBag.TotalClientes</h3>
                </div>
            </div>
        </div>

        <!-- Faturamento -->
        <div class="col-md-3">
            <div class="glass-card p-4 d-flex align-items-center">
                <div class="icon-box me-3 bg-pink-soft">
                    <i class="fas fa-chart-line fs-4 text-white"></i>
                </div>
                <div>
                    <small class="text-white-50 d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Faturamento</small>
                    <h3 class="text-white m-0 fw-bold">@(((decimal)ViewBag.Faturamento).ToString("C"))</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="mb-4">
        <div class="btn-group" role="tablist">
            <button class="btn btn-glass-tab active" data-bs-toggle="tab" data-bs-target="#products-tab" type="button" role="tab">
                <i class="fas fa-box me-2"></i> Produtos
            </button>
            <button class="btn btn-glass-tab" data-bs-toggle="tab" data-bs-target="#clients-tab" type="button" role="tab">
                <i class="fas fa-users me-2"></i> Clientes
            </button>
            <button class="btn btn-glass-tab" data-bs-toggle="tab" data-bs-target="#analytics-tab" type="button" role="tab">
                <i class="fas fa-chart-bar me-2"></i> Análises
            </button>
        </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content">
        <!-- Products Tab -->
        <div class="tab-pane fade show active" id="products-tab" role="tabpanel">
            <div class="glass-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="text-white fw-bold m-0">Gerenciar Produtos</h4>
                    <a asp-controller="Products" asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold" style="background: linear-gradient(90deg, #9b59b6, #e056fd); border: none;">
                        <i class="fas fa-plus me-2"></i> Novo Produto
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-dark table-borderless align-middle" style="background: transparent;">
                        <thead>
                            <tr class="text-white-50 border-bottom border-secondary">
                                <th scope="col" class="py-3">ID</th>
                                <th scope="col" class="py-3">Nome</th>
                                <th scope="col" class="py-3">Preço</th>
                                <th scope="col" class="py-3">Estoque</th>
                                <th scope="col" class="py-3">Status</th>
                                <th scope="col" class="text-end py-3">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="glass-row">
                                    <td class="text-white-50">#@item.Id</td>
                                    <td class="fw-bold text-white">@item.Nome</td>
                                    <td class="text-white">@item.PrecoVenda.ToString("C")</td>
                                    <td class="text-white">@item.Estoque un</td>
                                    <td>
                                        <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3">Ativo</span>
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-icon-glass me-2" title="Editar">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <a asp-controller="Products" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-icon-glass text-danger" title="Excluir">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Clients Tab -->
        <div class="tab-pane fade" id="clients-tab" role="tabpanel">
            <div class="glass-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="text-white fw-bold m-0">Gerenciar Clientes</h4>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-dark table-borderless align-middle" style="background: transparent;">
                        <thead>
                            <tr class="text-white-50 border-bottom border-secondary">
                                <th scope="col" class="py-3">ID</th>
                                <th scope="col" class="py-3">Nome</th>
                                <th scope="col" class="py-3">Telefone</th>
                                <th scope="col" class="py-3">Saldo Devedor</th>
                                <th scope="col" class="text-end py-3">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Clients != null)
                            {
                                foreach (var client in ViewBag.Clients)
                                {
                                    <tr class="glass-row">
                                        <td class="text-white-50">#@client.Id</td>
                                        <td class="fw-bold text-white">@client.Nome</td>
                                        <td class="text-white">@client.Telefone</td>
                                        <td class="text-white">@client.SaldoDevedor.ToString("C")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-icon-glass me-2" title="Editar"><i class="fas fa-pencil-alt"></i></button>
                                            <button class="btn btn-sm btn-icon-glass text-danger" title="Excluir"><i class="fas fa-trash-alt"></i></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Analytics Tab -->
        <div class="tab-pane fade" id="analytics-tab" role="tabpanel">
            <div class="glass-card p-4">
                <h4 class="text-white fw-bold mb-4">Análises de Vendas</h4>
                
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="p-4 rounded-3 border border-secondary bg-dark bg-opacity-25">
                            <h5 class="text-white mb-3">Últimas Vendas</h5>
                            <div class="table-responsive">
                                <table class="table table-sm table-dark table-borderless">
                                    <thead>
                                        <tr class="text-white-50">
                                            <th>Data</th>
                                            <th>Valor</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ViewBag.Sales != null)
                                        {
                                            foreach (var sale in ViewBag.Sales)
                                            {
                                                <tr>
                                                    <td class="text-white-50">@sale.DataVenda.ToString("dd/MM HH:mm")</td>
                                                    <td class="text-white fw-bold">@sale.ValorTotal.ToString("C")</td>
                                                    <td>
                                                        <span class="badge bg-success bg-opacity-10 text-success" style="font-size: 0.6rem;">@sale.Status</span>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 rounded-3 border border-secondary bg-dark bg-opacity-25 h-100">
                            <h5 class="text-white mb-3">Resumo Financeiro</h5>
                            <div class="d-flex flex-column gap-3">
                                <div class="p-3 rounded bg-purple-soft bg-opacity-10">
                                    <small class="text-white-50 d-block">Média por Venda</small>
                                    @if (ViewBag.VendasHoje > 0) {
                                        <h4 class="text-white m-0">@(((decimal)ViewBag.Faturamento / (int)ViewBag.VendasHoje).ToString("C"))</h4>
                                    } else {
                                        <h4 class="text-white m-0">R$ 0,00</h4>
                                    }
                                </div>
                                <div class="p-3 rounded bg-teal-soft bg-opacity-10">
                                    <small class="text-white-50 d-block">Vendas no Mês</small>
                                    <h4 class="text-white m-0">@ViewBag.VendasHoje</h4> <!-- Simplificado -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
