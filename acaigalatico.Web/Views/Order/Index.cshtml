@{
    ViewData["Title"] = "Fazer Pedido";
    var fruits = ViewBag.Fruits as List<string>;
    // Toppings is now a List<ToppingOption>
    var toppings = ViewBag.Toppings as dynamic; 
}

<div class="container-fluid p-0 overflow-hidden" style="height: 100vh;">
    <div class="row h-100 g-0">
        
        <!-- Left Column: Image -->
        <div class="col-lg-5 d-none d-lg-block position-relative">
            <div style="
                background: url('/images/acai-expo-1.jpeg') no-repeat center center/cover; 
                height: 100%; 
                width: 100%;
                filter: brightness(0.9);">
            </div>
            <div class="position-absolute bottom-0 start-0 p-5 text-white" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); width: 100%;">
                <h1 class="display-4 fw-bold">Sabor de Outro Mundo</h1>
                <p class="lead">Monte o açaí perfeito para sua viagem galáctica.</p>
            </div>
        </div>

        <!-- Right Column: Form -->
        <div class="col-lg-7 h-100 position-relative" style="background: url('/images/galaxiaa.jpg') no-repeat center center/cover;">
             <!-- Dark Overlay -->
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 10, 30, 0.85); z-index: 0;"></div>

            <div class="position-relative h-100 d-flex flex-column" style="z-index: 1; padding-top: 150px;">
                
                <!-- Header Fixed -->
                <div class="p-4 border-bottom border-secondary bg-black bg-opacity-50">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="text-white m-0 text-uppercase fw-bold"><i class="fas fa-rocket text-warning me-2"></i> Monte seu Açaí Galáctico</h4>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill"><i class="fas fa-times"></i> Fechar</a>
                    </div>
                </div>

                <!-- Scrollable Content -->
                <div class="flex-grow-1 overflow-auto p-4 custom-scrollbar">
                    <form asp-action="SubmitOrder" method="post" id="orderForm">
                        
                        <!-- 1. Tipo e Tamanho (Cards Compactos) -->
                        <div class="card glass-panel mb-4">
                            <div class="card-body">
                                <h5 class="card-title text-white mb-3"><i class="fas fa-wine-glass-alt text-warning me-2"></i> Base e Tamanho</h5>
                                
                                <!-- Tipo -->
                                <div class="mb-3">
                                    <label class="text-white-50 small mb-2">ESCOLHA O TIPO</label>
                                    <div class="btn-group w-100" role="group">
                                        <input type="radio" class="btn-check" name="type" id="type-tradicional" value="Tradicional" checked onchange="updatePrices()">
                                        <label class="btn btn-outline-light" for="type-tradicional">Tradicional</label>

                                        <input type="radio" class="btn-check" name="type" id="type-trufado" value="Trufado" onchange="updatePrices()">
                                        <label class="btn btn-outline-light" for="type-trufado">Trufado</label>

                                        <input type="radio" class="btn-check" name="type" id="type-gourmet" value="Gourmet" onchange="updatePrices()">
                                        <label class="btn btn-outline-light" for="type-gourmet">Gourmet</label>
                                    </div>
                                </div>

                                <!-- Tamanho -->
                                <div>
                                    <label class="text-white-50 small mb-2">ESCOLHA O TAMANHO</label>
                                    <div class="row g-2" id="size-options">
                                        <!-- Populated by JS -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 2. Quantidade -->
                        <div class="card glass-panel mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="text-white m-0">Quantidade</h5>
                                    <small class="text-white-50">Quantos açaís iguais a este?</small>
                                </div>
                                <div class="input-group" style="width: 140px;">
                                    <button class="btn btn-outline-light" type="button" onclick="changeQuantity(-1)"><i class="fas fa-minus"></i></button>
                                    <input type="text" class="form-control text-center bg-transparent text-white border-light" id="quantity" name="quantity" value="1" readonly>
                                    <button class="btn btn-outline-light" type="button" onclick="changeQuantity(1)"><i class="fas fa-plus"></i></button>
                                </div>
                            </div>
                        </div>

                        <!-- 3. Frutas -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="text-white m-0">Frutas <small class="text-warning fs-6 ms-2" id="fruit-limit-text"></small></h5>
                                <i class="fas fa-check text-success" id="fruit-check-icon" style="display:none;"></i>
                            </div>
                            <div class="list-group glass-list">
                                @foreach (var fruit in fruits)
                                {
                                    <label class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-transparent text-white border-secondary">
                                        <div>
                                            <span class="fw-bold">@fruit</span>
                                            <small class="d-block text-white-50">Fruta fresca selecionada</small>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input fruit-check fs-4" type="checkbox" name="fruits" value="@fruit">
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- 4. Acompanhamentos (Lista Rica) -->
                        <div class="mb-5">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="text-white m-0">Acompanhamentos <small class="text-warning fs-6 ms-2" id="topping-limit-text"></small></h5>
                                <i class="fas fa-check text-success" id="topping-check-icon" style="display:none;"></i>
                            </div>
                            <div class="list-group glass-list">
                                @foreach (var item in toppings)
                                {
                                    <label class="list-group-item list-group-item-action d-flex align-items-center bg-transparent text-white border-secondary p-3">
                                        <img src="@item.ImageUrl" class="rounded-circle me-3 border border-light" style="width: 50px; height: 50px; object-fit: cover;">
                                        <div class="flex-grow-1">
                                            <span class="fw-bold d-block">@item.Name</span>
                                            <small class="text-white-50">@item.Description</small>
                                        </div>
                                        <div class="form-check ms-3">
                                            <input class="form-check-input topping-check fs-4" type="checkbox" name="toppings" value="@item.Name">
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- 5. Observação sobre Entrega -->
                        <div class="card glass-panel mb-4 border-warning" style="border-style: dashed;">
                            <div class="card-body text-center">
                                <h5 class="card-title text-warning mb-3"><i class="fas fa-motorcycle me-2"></i> Entrega / Retirada</h5>
                                <p class="text-white-50 mb-3" style="font-size: 0.95rem;">
                                    Prezado cliente, informamos que no momento <strong>não dispomos de entregadores próprios</strong>.
                                    <br>Recomendamos solicitar a retirada do seu pedido via <strong>Uber Moto</strong>.
                                </p>
                                <a href="https://m.uber.com/" target="_blank" class="btn btn-outline-light w-100 fw-bold hover-warning">
                                    <i class="fab fa-uber me-2"></i> Abrir Aplicativo Uber
                                </a>
                            </div>
                        </div>

                    </form>
                </div>

                <!-- Footer Fixed -->
                <div class="p-3 border-top border-secondary bg-black bg-opacity-75">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-white-50 d-block">Total do Pedido</small>
                            <span id="total-price" class="h2 text-warning fw-bold m-0">R$ 0,00</span>
                        </div>
                        <button type="button" onclick="document.getElementById('orderForm').submit()" class="btn btn-success btn-lg rounded-pill px-5 fw-bold shadow-lg">
                            <i class="fas fa-check me-2"></i> Concluir
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const prices = {
            "Tradicional": { "300ml": 10, "400ml": 12, "500ml": 15, "700ml": 18 },
            "Trufado": { "300ml": 13, "400ml": 15, "500ml": 17, "700ml": 22 },
            "Gourmet": { "300ml": 15, "400ml": 17, "500ml": 20, "700ml": 25 }
        };

        const limits = {
            "300ml": { fruits: 1, toppings: 2 },
            "400ml": { fruits: 1, toppings: 3 },
            "500ml": { fruits: 2, toppings: 4 },
            "700ml": { fruits: 2, toppings: 5 }
        };

        let currentType = "Tradicional";
        let currentSize = "300ml";
        let quantity = 1;

        function updatePrices() {
            // Get selected type
            const typeRadios = document.getElementsByName("type");
            for (const radio of typeRadios) {
                if (radio.checked) {
                    currentType = radio.value;
                    break;
                }
            }

            // Render Size Options
            const sizeContainer = document.getElementById("size-options");
            sizeContainer.innerHTML = "";
            
            const sizePrices = prices[currentType];
            for (const [size, price] of Object.entries(sizePrices)) {
                const isChecked = size === currentSize ? "checked" : "";
                const activeClass = size === currentSize ? "active-size" : "";
                
                const col = document.createElement("div");
                col.className = "col-6";
                col.innerHTML = `
                    <input type="radio" class="btn-check size-radio" name="size" id="size-${size}" value="${size}" ${isChecked} onchange="updateSize(this.value)">
                    <label class="btn btn-outline-light w-100 p-2 d-flex justify-content-between align-items-center ${activeClass}" for="size-${size}">
                        <span class="fw-bold">${size}</span>
                        <span class="badge bg-light text-dark">R$ ${price.toFixed(2).replace('.', ',')}</span>
                    </label>
                `;
                sizeContainer.appendChild(col);
            }

            updateTotal();
        }

        function updateSize(size) {
            currentSize = size;
            updateLimits();
            updateTotal();
        }

        function changeQuantity(delta) {
            quantity += delta;
            if (quantity < 1) quantity = 1;
            document.getElementById("quantity").value = quantity;
            updateTotal();
        }

        function updateLimits() {
            const limit = limits[currentSize];
            
            document.getElementById("fruit-limit-text").textContent = `(Escolha até ${limit.fruits})`;
            document.getElementById("topping-limit-text").textContent = `(Escolha até ${limit.toppings})`;

            validateCheckboxes('fruit-check', limit.fruits);
            validateCheckboxes('topping-check', limit.toppings);
        }

        function updateTotal() {
            const unitPrice = prices[currentType][currentSize];
            const total = unitPrice * quantity;
            document.getElementById("total-price").textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
        }

        function validateCheckboxes(className, max) {
            const checkboxes = document.querySelectorAll('.' + className);
            let checkedCount = 0;
            
            checkboxes.forEach(cb => {
                if (cb.checked) checkedCount++;
            });

            // Update icon status
            const iconId = className === 'fruit-check' ? 'fruit-check-icon' : 'topping-check-icon';
            const icon = document.getElementById(iconId);
            if (checkedCount > 0) {
                icon.style.display = 'block';
                if (checkedCount === max) icon.className = "fas fa-check-circle text-success";
                else icon.className = "fas fa-check text-success";
            } else {
                icon.style.display = 'none';
            }

            checkboxes.forEach(cb => {
                if (!cb.checked) {
                    cb.disabled = checkedCount >= max;
                    if (cb.disabled) {
                        cb.closest('label').classList.add('opacity-50');
                    } else {
                        cb.closest('label').classList.remove('opacity-50');
                    }
                } else {
                    cb.disabled = false;
                    cb.closest('label').classList.remove('opacity-50');
                }
            });
        }

        // Initialize
        document.addEventListener("DOMContentLoaded", () => {
            updatePrices(); // Initial render
            updateLimits();

            document.addEventListener('change', (e) => {
                if (e.target.classList.contains('fruit-check')) {
                    const limit = limits[currentSize].fruits;
                    validateCheckboxes('fruit-check', limit);
                }
                if (e.target.classList.contains('topping-check')) {
                    const limit = limits[currentSize].toppings;
                    validateCheckboxes('topping-check', limit);
                }
            });
        });
    </script>
    <style>
        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.1); 
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.3); 
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.5); 
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 15px;
        }

        .glass-list .list-group-item {
            transition: all 0.2s;
        }
        .glass-list .list-group-item:hover {
            background: rgba(255, 255, 255, 0.05) !important;
        }

        .form-check-input:checked {
            background-color: #2ecc71;
            border-color: #2ecc71;
        }

        .active-size {
            background-color: rgba(255, 255, 255, 0.2);
            border-color: #fff;
        }
        
        .opacity-50 {
            opacity: 0.5;
            pointer-events: none; /* Optional: prevent interaction if visual cue is strong */
        }
    </style>
}
