@model acaigalatico.Application.DTOs.ProdutoDTO

@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="container p-4 border rounded bg-light">
    <h3 class="text-danger">Excluir Produto</h3>
    <h5 class="alert alert-warning">Você tem certeza que deseja excluir este item?</h5>
    <hr />

    <div class="row">
        <dl class="row">
            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(model => model.Nome)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Nome)
            </dd>

            <dt class="col-sm-3 fw-bold">
                Preço
            </dt>
            <dd class="col-sm-9">
                @Model.PrecoVenda.ToString("C")
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(model => model.Descricao)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Descricao)
            </dd>

            <dt class="col-sm-3 fw-bold">
                Categoria (ID)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.CategoriaId)
            </dd>
        </dl>
        
        @if (!string.IsNullOrEmpty(Model.ImagemUrl))
        {
            <div class="col-12 mb-3">
                <p class="fw-bold">Imagem:</p>
                <img src="@Model.ImagemUrl" width="150" class="rounded border" />
            </div>
        }
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="mt-3">
            <input type="submit" value="Confirmar Exclusão" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </div>
    </form>
</div>
